generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  PROBATION
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  WFH
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  role          Role     @default(EMPLOYEE)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions        Session[]
  accounts        Account[]
  departmentId    String?
  department      Department?      @relation(fields: [departmentId], references: [id])
  employeeProfile EmployeeProfile?

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  employees User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("department")
}

model EmployeeProfile {
  id               String           @id @default(uuid())
  employeeCode     String           @unique // e.g., "EMP-0001"
  employmentStatus EmploymentStatus @default(PROBATION)
  joinDate         DateTime         @default(now())
  userId           String           @unique
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  attendanceRecords Attendance[]
  leaveRequests     Leave[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employee_profile")
}

model Attendance {
  id       String           @id @default(uuid())
  date     DateTime         @default(now()) // Stored as YYYY-MM-DD format
  clockIn  DateTime         @default(now())
  clockOut DateTime?
  status   AttendanceStatus @default(PRESENT)

  // Geolocation Perimeter Verification Tracking
  lat      Float?
  lng      Float?

  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, date])
  @@map("attendance")
}

model Leave {
  id        String      @id @default(uuid())
  leaveType String
  startDate DateTime
  endDate   DateTime
  reason    String
  status    LeaveStatus @default(PENDING)

  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leave")
}
